<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>🏆 Copa 2026 Ultimate</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Poppins;
}

body{
background:#081018;
color:white;
}

header{

height:70vh;

background:
linear-gradient(rgba(0,0,0,.6),rgba(0,0,0,.6)),
url("https://images.unsplash.com/photo-1574629810360-7efbbe195018?q=80&w=2070");

background-size:cover;
background-position:center;

display:flex;
justify-content:center;
align-items:center;
text-align:center;

}

header h1{

font-size:60px;

}

header p{

font-size:20px;

margin-top:20px;

}

/* seleção */

.selecoes{

padding:50px;
display:flex;
justify-content:center;
gap:25px;
flex-wrap:wrap;

}

.time{

background:#111f2e;
padding:20px;
width:170px;
text-align:center;
border-radius:20px;
cursor:pointer;
transition:.5s;
border:2px solid transparent;

}

.time:hover{

border-color:#00ff95;
transform:translateY(-8px);

}

.time img{

width:80px;

}

/* campo */

#areaTime{

padding:50px;

display:none;

}

.info{

display:flex;
justify-content:space-around;
margin-bottom:30px;
flex-wrap:wrap;
gap:20px;

}

.box{

background:#111f2e;
padding:15px;
border-radius:15px;

}

.campo{

height:800px;

position:relative;

background:url("https://img.freepik.com/free-vector/football-field_1284-42125.jpg");

background-size:cover;

border-radius:30px;

overflow:hidden;

}

.player{

position:absolute;
transform:translate(-50%,-50%);
text-align:center;

}

.player img{

width:80px;
height:80px;
border-radius:50%;
border:3px solid #00ff95;

}

.card{

background:#111f2e;
padding:5px;
border-radius:10px;
font-size:12px;
margin-top:5px;
}

</style>

</head>

<body>


<header>

<div>

<h1>🏆 Copa do Mundo 2026</h1>

<p>
Escolha uma seleção para ver formação estilo FIFA
</p>

</div>

</header>


<div class="selecoes">

<div class="time" onclick="carregar('brasil')">

<img src="https://flagcdn.com/w320/br.png">

<h2>Brasil</h2>

</div>


<div class="time" onclick="carregar('portugal')">

<img src="https://flagcdn.com/w320/pt.png">

<h2>Portugal</h2>

</div>


<div class="time" onclick="carregar('argentina')">

<img src="https://flagcdn.com/w320/ar.png">

<h2>Argentina</h2>

</div>


<div class="time" onclick="carregar('franca')">

<img src="https://flagcdn.com/w320/fr.png">

<h2>França</h2>

</div>

</div>


<section id="areaTime">

<div class="info">

<div class="box" id="tecnico"></div>

<div class="box" id="estadio"></div>

<div class="box" id="formacao"></div>

</div>


<div class="campo" id="campo"></div>

</section>


<script>

const dados={

brasil:{

tecnico:"👨‍🏫 Dorival Jr",
estadio:"🏟 MetLife Stadium",
formacao:"⚽ 4-3-3",

jogadores:[

["Alisson","GK",90,50,90,"https://randomuser.me/api/portraits/men/1.jpg"],

["Marquinhos","CB",89,25,70,"https://randomuser.me/api/portraits/men/2.jpg"],

["Militão","CB",88,75,70,"https://randomuser.me/api/portraits/men/3.jpg"],

["Paquetá","CM",87,30,50,"https://randomuser.me/api/portraits/men/4.jpg"],

["Casemiro","CDM",89,70,50,"https://randomuser.me/api/portraits/men/5.jpg"],

["Vini Jr","ST",92,50,20,"https://randomuser.me/api/portraits/men/6.jpg"]

]

},


portugal:{

tecnico:"👨‍🏫 Roberto Martínez",
estadio:"🏟 SoFi Stadium",
formacao:"⚽ 4-3-3",

jogadores:[

["Diogo Costa","GK",89,50,90,"https://randomuser.me/api/portraits/men/7.jpg"],

["Ruben Dias","CB",90,30,70,"https://randomuser.me/api/portraits/men/8.jpg"],

["Pepe","CB",87,70,70,"https://randomuser.me/api/portraits/men/9.jpg"],

["Bruno Fernandes","CAM",91,40,45,"https://randomuser.me/api/portraits/men/10.jpg"],

["Bernardo Silva","CM",91,65,45,"https://randomuser.me/api/portraits/men/11.jpg"],

["Cristiano Ronaldo","ST",93,50,20,"https://randomuser.me/api/portraits/men/12.jpg"]

]

}

}


function carregar(time){

document.getElementById("areaTime")
.style.display="block"

let t=dados[time]

tecnico.innerHTML=t.tecnico
estadio.innerHTML=t.estadio
formacao.innerHTML=t.formacao

campo.innerHTML=""

t.jogadores.forEach(j=>{

campo.innerHTML+=`

<div class='player'
style='left:${j[3]}%;top:${j[4]}%'>

<img src="${j[5]}">

<div class='card'>

${j[0]}<br>

${j[1]} | OVR ${j[2]}

</div>

</div>

`

})

}

</script>

</body>
</html>
